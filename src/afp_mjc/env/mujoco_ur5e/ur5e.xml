<mujoco model="ur5e">
  <compiler angle="radian" meshdir="assets" autolimits="true"/>
  <!-- <include file="../AFPhead/mjcf/AFPhead.xml"/> -->
  <option integrator="implicitfast" gravity="0 0 -9.81"/>
  <!-- <keypoint>
    <key name="home" qpos="0 -1.57 1.57 -1.57 -1.57 0"/>
  </keypoint> -->
  <default>
    <default class="ur5e">
      <material specular="0.5" shininess="0.25"/>
      <joint axis="0 1 0" range="-6.28319 6.28319" armature="0.1"/>
      <general gaintype="fixed" biastype="affine" ctrlrange="-6.2831 6.2831" gainprm="2000" biasprm="0 -2000 -200" forcerange="-2000 2000"/>
      <default class="size3">
        <default class="size3_limited">
          <joint range="-3.1415 3.1415"/>
          <general ctrlrange="-3.1415 3.1415"/>
        </default>
      </default>
      <default class="size1">
        <general gainprm="1000" biasprm="0 -1000 -200" forcerange="-28 28"/>
      </default>
      <default class="visual">
        <geom type="mesh" contype="0" conaffinity="0" group="2"/>
      </default>
      <default class="collision">
        <geom type="capsule" group="3"/>
        <default class="eef_collision">
          <geom type="cylinder"/>
        </default>
      </default>
      <site size="0.001" rgba="0.5 0.5 0.5 0.3" group="4"/>
    </default>
    <!-- robotiq_gripper -->
    <default class="2f85">
      <mesh scale="0.001 0.001 0.001"/>
      <!-- <general ctrllimited="true" forcelimited="true" biastype="none"/> -->
      <joint axis="1 0 0" limited="false"/>
      <default class="robotiq_85_outter_knuckle_link">
        <joint limited="true" range="0 0.834" solimplimit="0.95 0.99 0.001" solreflimit="0.005 1" armature="0.005" damping="0.1" />
      </default>
      <default class="robotiq_85_finger_tip_link">
        <joint limited="true" armature="0.001" range="-0.872664 0.872664" pos="0 -0.018 0.0065" solimplimit="0.95 0.99 0.001" solreflimit="0.005 1"/>
      </default>
      <default class="robotiq_85_inner_knuckle_link">
        <joint limited="true" armature="0.001" range="-0.29670597283 0.8" stiffness="0.05" springref="2.62" damping="0.00125"/>
      </default>
      <default class="robotiq_85_finger_link">
        <joint limited="true" armature="0.001" range="-1.57 0" solimplimit="0.95 0.99 0.001" solreflimit="0.005 1"/>
      </default>
      <default class="visual_2f85">
        <geom type="mesh" contype="0" conaffinity="0" group="2"/>
      </default>
      <default class="collision_2f85">
        <geom type="mesh" group="3"/>
        <default class="robotiq_85_finger_pad_box1">
          <geom mass="0.0" type="box" pos="0 -0.0026 0.028125" size="0.011 0.004 0.009375" friction="0.0" solimp="0.95 0.99 0.001" solref="0.004 1" priority="1" rgba="0.55 0.55 0.55 1"/>
          <!-- mass="0.1" -->
        </default>
        <default class="robotiq_85_finger_pad_box2">
          <geom mass="0.0" type="box" pos="0 -0.0026 0.009375" size="0.011 0.004 0.009375" friction="0.0" solimp="0.95 0.99 0.001" solref="0.004 1" priority="1" rgba="0.45 0.45 0.45 1"/>
          <!-- mass="0.1" -->
        </default>
      </default>
    </default>


  </default>

  <asset>
